NODE_ENV=development
PORT=5000
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.exn8dlzy.mongodb.net/vanca_patina?retryWrites=true&w=majority

# Used for signing/verifying JWT access tokens
JWT_SECRET=your_super_secret_jwt_key

# Comma-separated list of allowed frontend origins for CORS
# Add your deployed frontend URL(s) in production.
CLIENT_URL=http://localhost:8080,http://localhost:5173,http://192.168.1.67:8080
FRONTEND_URL=http://localhost:8080
API_BASE_URL=http://localhost:5000
REQUIRE_EMAIL_VERIFICATION=true

# Cloudinary credentials (optional; if not set, backend will keep local uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email/SMTP configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
FROM_NAME=Vanca Patina

# Razorpay payment gateway
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# Invoice branding
COMPANY_NAME=Vanca Patina
COMPANY_GST_NUMBER=GSTIN1234567890
COMPANY_ADDRESS=123 Business Street, Jaipur, Rajasthan, India
COMPANY_LOGO_URL=
